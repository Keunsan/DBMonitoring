# 통합 DB 모니터링 시스템 환경 변수 템플릿
# 실제 값은 .env.local 또는 배포 환경의 Secret Manager에 설정합니다.
# 비밀번호, token, connection string은 Git에 커밋하지 않습니다.

# -----------------------------------------------------------------------------
# App / Runtime
# -----------------------------------------------------------------------------
APP_ENV=development
NEXT_PUBLIC_APP_NAME="통합 DB 모니터링"
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Supabase / 운영 DB (T-008, T-019)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Secret 저장소: supabase_vault(운영/Vault ref) | env_local(개발/env: ref)
SECRET_PROVIDER=env_local
SECRET_KEY_PREFIX=dbmonitoring
# Vault 사용 시 migration 적용: supabase/migrations/202605271200_connection_secrets_vault.sql

# -----------------------------------------------------------------------------
# SSO / Auth (T-009)
# -----------------------------------------------------------------------------
SSO_PROVIDER=mock
SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_CALLBACK_URL=http://localhost:3000/api/auth/callback
AUTH_SESSION_SECRET=
AUTH_COOKIE_NAME=dbmonitoring_session

# -----------------------------------------------------------------------------
# ERP 테스트 DB / 개발용 연결 확인 API
# -----------------------------------------------------------------------------
ERP_TEST_DB_HOST=
ERP_TEST_DB_PORT=1433
ERP_TEST_DB_NAME=
ERP_TEST_DB_USER=
ERP_TEST_DB_PASSWORD=
ERP_TEST_DB_ENCRYPT=true
ERP_TEST_DB_TRUST_SERVER_CERTIFICATE=true
ERP_TEST_DB_CONNECTION_TIMEOUT_MS=5000
ERP_TEST_DB_REQUEST_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# Collector / Worker (T-014~T-016)
# -----------------------------------------------------------------------------
COLLECTOR_ID=local-dev-collector
COLLECTOR_DEFAULT_INTERVAL_SEC=30
COLLECTOR_SQL_AGGREGATE_INTERVAL_SEC=300

# -----------------------------------------------------------------------------
# Notification (T-024)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
TEAMS_WEBHOOK_URL=
